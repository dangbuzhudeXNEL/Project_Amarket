# Project_Amarket — 环境变量模板
# 复制为 .env 并填实际值。.env 已被 .gitignore 保护，**永不入库**。

# ============================================================
# Phase 1 必填（M0 末用于 hello 推送验证）
# ============================================================

# 业务推送：企业微信群机器人 webhook
WEWORK_BOT_WEBHOOK_URL=

# 告警专用：企业微信群机器人 webhook（应与业务渠道分离，避免告警自被节流）
WEWORK_ALERT_BOT_WEBHOOK_URL=

# 飞书机器人 webhook（备用 / P0 双发）
LARK_BOT_WEBHOOK_URL=

# 邮件（仅 P0 备用）
# EMAIL_SMTP_HOST=smtp.example.com
# EMAIL_SMTP_PORT=465
# EMAIL_USER=
# EMAIL_PASS=

# ============================================================
# Phase 1 AI（至少配一个；用于新闻分析 SDK 路径）
# ============================================================

# Anthropic（主）
# ANTHROPIC_API_KEY=sk-ant-xxxxx
# ANTHROPIC_BASE_URL=

# DeepSeek（兼容 OpenAI 协议，备用）
# DEEPSEEK_API_KEY=sk-xxxxx

# ============================================================
# Phase 2 Brainmaster（无 API key 需求；仅需 Claude CLI 在 PATH）
# ============================================================
# CLAUDE_CLI_PATH=claude          # 默认 PATH 中可直接调用

# ============================================================
# Telegram（Phase 2 stub，MVP 不启用）
# ============================================================
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=

# ============================================================
# 应用运行时
# ============================================================
APP_ENV=dev                       # dev | test | prod
LOG_LEVEL=INFO                    # DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_FORMAT=json                   # json | console（开发用 console 更易读）
